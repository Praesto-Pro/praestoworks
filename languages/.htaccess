
Options -Indexes
# Apache 2.4+
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

# Apache 2.2 (legacy)
<IfModule !mod_authz_core.c>
    Order Deny,Allow
    Deny from all
</IfModule>

<FilesMatch "^.*$">
    ForceType text/plain
</FilesMatch>

<Files "index.php">
    # Apache 2.4
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>

    # Apache 2.2
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>

    # If server uses mod_php, disable PHP engine
    <IfModule mod_php.c>
        php_flag engine off
    </IfModule>
</Files>